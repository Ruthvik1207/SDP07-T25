torage.clear();\n    setAuthToken(null);\n    setCurrentUser(null);\n    setUserRole(null);\n  };\n\n  return (\n    <AuthCtx.Provider value={{ authToken, currentUser, userRole, login, logout }}>\n      {children}\n    </AuthCtx.Provider>\n  );\n};\n\nexport default AuthContext;\n"],"mappings":"AAAA,MAAO,CAAAA,KAAK,EAAIC,aAAa,CAAEC,QAAQ,KAAQ,OAAO,CAAC,OAAAC,GAAA,IAAAC,IAAA,yBAEvD,MAAO,MAAM,CAAAC,OAAO,cAAGJ,aAAa,CAAC,IAAI,CAAC,CAE1C,KAAM,CAAAK,WAAW,CAAGC,IAAA,EAAkB,IAAjB,CAAEC,QAAS,CAAC,CAAAD,IAAA,CAC/B,KAAM,CAACE,SAAS,CAAEC,YAAY,CAAC,CAAGR,QAAQ,CAACS,YAAY,CAACC,OAAO,CAAC,OAAO,CAAC,EAAI,IAAI,CAAC,CACjF,KAAM,CAACC,WAAW,CAAEC,cAAc,CAAC,CAAGZ,QAAQ,CAACS,YAAY,CAACC,OAAO,CAAC,SAAS,CAAC,EAAI,IAAI,CAAC,CACvF,KAAM,CAACG,QAAQ,CAAEC,WAAW,CAAC,CAAGd,QAAQ,CAACS,YAAY,CAACC,OAAO,CAAC,MAAM,CAAC,EAAI,IAAI,CAAC,CAE9E,KAAM,CAAAK,KAAK,CAAGA,CAACC,KAAK,CAAEC,IAAI,CAAEC,IAAI,GAAK,CACnCT,YAAY,CAACU,OAAO,CAAC,OAAO,CAAEH,KAAK,CAAC,CACpCP,YAAY,CAACU,OAAO,CAAC,SAAS,CAAEF,IAAI,CAAC,CACrCR,YAAY,CAACU,OAAO,CAAC,MAAM,CAAED,IAAI,CAAC,CAClCV,YAAY,CAACQ,KAAK,CAAC,CACnBJ,cAAc,CAACK,IAAI,CAAC,CACpBH,WAAW,CAACI,IAAI,CAAC,CACnB,CAAC,CAED,KAAM,CAAAE,MAAM,CAAGA,CAAA,GAAM,CACnBX,YAAY,CAACY,KAAK,CAAC,CAAC,CACpBb,YAAY,CAAC,IAAI,CAAC,CAClBI,cAAc,CAAC,IAAI,CAAC,CACpBE,WAAW,CAAC,IAAI,CAAC,CACnB,CAAC,CAED,mBACEZ,IAAA,CAACC,OAAO,CAACmB,QAAQ,EAACC,KAAK,CAAE,CAAEhB,SAAS,CAAEI,WAAW,CAAEE,QAAQ,CAAEE,KAAK,CAAEK,MAAO,CAAE,CAAAd,QAAA,CAC1EA,QAAQ,CACO,CAAC,CAEvB,CAAC,CAED,cAAe,CAAAF,WAAW","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}